# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0  # Main model for text
BEDROCK_VISION_MODEL_ID=us.amazon.nova-pro-v1:0  # For image analysis
BEDROCK_TEMPERATURE=0.7
BEDROCK_MAX_TOKENS=4096
DYNAMODB_MARKET_PRICES_TABLE=grambrain_market_prices
DYNAMODB_SESSIONS_TABLE=grambrain_sessions
DYNAMODB_ANALYTICS_TABLE=grambrain_analytics
WEATHER_API_KEY=your_openweathermap_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key_optional
MANDI_API_KEY=your_data_gov_api_key_optional