# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# LLM Configuration
DEFAULT_LLM_MODEL=anthropic.claude-3-sonnet-20240229-v1:0
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# RAG Configuration
VECTOR_DB_TYPE=in_memory  # in_memory, opensearch, pinecone
OPENSEARCH_ENDPOINT=https://your-opensearch-endpoint:9200
EMBEDDING_MODEL=amazon.titan-embed-text-v1

# System Configuration
LOG_LEVEL=INFO
AGENT_TIMEOUT=10
