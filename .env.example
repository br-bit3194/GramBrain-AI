# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# DynamoDB Configuration
DYNAMODB_ENV=dev  # dev, staging, production
DYNAMODB_ENDPOINT_URL=  # Leave empty for AWS DynamoDB, set for LocalStack/DynamoDB Local
DYNAMODB_RETRY_MAX_ATTEMPTS=3
DYNAMODB_RETRY_BASE_DELAY_MS=100
DYNAMODB_RETRY_MAX_DELAY_MS=5000

# LLM Configuration
DEFAULT_LLM_MODEL=anthropic.claude-3-sonnet-20240229-v1:0
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# S3 Configuration
S3_BUCKET_NAME=gram-brain-bucket
S3_MAX_FILE_SIZE_MB=50
S3_PRESIGNED_URL_EXPIRATION=3600  # 1 hour in seconds

# RAG Configuration
VECTOR_DB_TYPE=in_memory  # in_memory, opensearch, pinecone
OPENSEARCH_ENDPOINT=https://your-opensearch-endpoint:9200
OPENSEARCH_INDEX_NAME=grambrain-knowledge
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=true
OPENSEARCH_TIMEOUT=30
EMBEDDING_MODEL=amazon.titan-embed-text-v1
EMBEDDING_DIMENSION=1536
RAG_CACHE_TTL_HOURS=24

# System Configuration
LOG_LEVEL=INFO
AGENT_TIMEOUT=10

# External API Configuration
OPENWEATHER_API_KEY=your_openweather_api_key
IMD_API_KEY=your_imd_api_key
SENTINEL_API_KEY=your_sentinel_api_key
AGMARKNET_API_KEY=your_agmarknet_api_key
WEATHER_CACHE_TTL_HOURS=3
SATELLITE_CACHE_TTL_HOURS=24
